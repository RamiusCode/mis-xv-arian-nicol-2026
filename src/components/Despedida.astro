---

<section class="py-10 px-8 flex flex-col items-center text-center">
  <div
    class="w-full max-w-xs border border-[#c9932a]/40 rounded-2xl bg-white/20 backdrop-blur-sm px-6 py-5"
  >
    <!-- Línea decorativa superior -->
    <div class="flex items-center gap-2 mb-3">
      <div class="flex-1 h-px bg-[#c9932a]/30"></div>
      <svg
        class="w-3 h-3 text-[#c9932a]"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
        ></path>
      </svg>
      <div class="flex-1 h-px bg-[#c9932a]/30"></div>
    </div>

    <p class="font-charm text-xl text-[#c9932a] mb-1">
      Este pase es válido para
    </p>

    <span class="font-charm text-5xl font-bold text-[#c9932a] leading-none"
      >1</span
    >
    <p class="font-charm text-xl text-[#7a5c2e]">Persona</p>

    <div class="border-t border-dashed border-[#c9932a]/30 my-3"></div>

    <p class="font-charm text-xl text-[#c9932a]/70 italic">
      Te esperamos con cariño
    </p>

    <!-- Línea decorativa inferior -->
    <div class="flex items-center gap-2 mt-3">
      <div class="flex-1 h-px bg-[#c9932a]/30"></div>
      <svg
        class="w-3 h-3 text-[#c9932a]"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
        ></path>
      </svg>
      <div class="flex-1 h-px bg-[#c9932a]/30"></div>
    </div>
  </div>
</section>
