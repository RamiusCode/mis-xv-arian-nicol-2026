<!-- REPRODUCTOR SIMPLE Y ELEGANTE - DORADO -->
<div class="w-full max-w-[320px] mx-auto" id="music-player-container">
  <!-- Texto superior -->
  <p class="text-center text-[#c9932a] text-sm mb-3 tracking-wide">
    Dale play para reproducir la canción
  </p>

  <!-- Card simple -->
  <div
    class="bg-white/20 backdrop-blur-md border border-[#D4AF37]/30 rounded-2xl px-6 py-4 shadow-md"
    id="player-card"
  >
    <!-- Barra de progreso -->
    <div class="mb-3">
      <input
        type="range"
        id="progressBar"
        value="0"
        max="100"
        class="w-full h-1 rounded-full appearance-none cursor-pointer slider-elegant"
      />
      <div class="flex justify-between text-xs text-[#D4AF37]/70 mt-1">
        <span id="currentTime">0:00</span>
        <span id="totalDuration">--:--</span>
      </div>
    </div>

    <!-- Controles -->
    <div class="flex items-center justify-center gap-6">
      <!-- Shuffle -->
      <button
        id="shuffleBtn"
        class="text-[#D4AF37]/50 hover:text-[#D4AF37] transition-all duration-200 focus:outline-none"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M17 17h-2l3-3 3 3h-2v2a4 4 0 01-4 4H8l2-2h5a2 2 0 002-2v-2zM7 7h2L6 4 3 7h2v2a4 4 0 004 4h7l-2 2H9a2 2 0 01-2-2V7z"
          ></path>
        </svg>
      </button>

      <!-- Anterior -->
      <button
        id="prevBtn"
        class="text-[#D4AF37]/70 hover:text-[#D4AF37] transition-all duration-200 focus:outline-none"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 6h2v12H6V6zm3.5 6l8.5 6V6l-8.5 6z"></path>
        </svg>
      </button>

      <!-- Play/Pause principal -->
      <button
        id="playPauseBtn"
        class="bg-[#D4AF37] hover:bg-[#c9932a] text-white rounded-full w-12 h-12 flex items-center justify-center shadow-lg transition-all duration-200 hover:scale-110 focus:outline-none"
      >
        <svg
          id="play-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M8 5v14l11-7z"></path>
        </svg>
        <svg
          id="pause-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="hidden"
        >
          <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"></path>
        </svg>
      </button>

      <!-- Siguiente -->
      <button
        id="nextBtn"
        class="text-[#D4AF37]/70 hover:text-[#D4AF37] transition-all duration-200 focus:outline-none"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18 6h-2v12h2V6zM12.5 12L4 6v12l8.5-6z"></path>
        </svg>
      </button>

      <!-- Repetir -->
      <button
        id="repeatBtn"
        class="text-[#D4AF37]/50 hover:text-[#D4AF37] transition-all duration-200 focus:outline-none"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<!-- Audio -->
<audio id="music-audio" preload="auto">
  <source src="/audio/melodia.mp3" type="audio/mpeg" />
</audio>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let isPlaying = false;
  let currentTime = 0;
  let duration = 0;

  document.addEventListener("DOMContentLoaded", () => {
    gsap.set("#music-player-container", { opacity: 0, y: 30 });

    ScrollTrigger.create({
      trigger: "#music-player-container",
      start: "top 100%",
      onEnter: () => {
        gsap.to("#music-player-container", {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power3.out",
        });
      },
      onEnterBack: () => {
        gsap.to("#music-player-container", {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power3.out",
        });
      },
      onLeaveBack: () => {
        gsap.to("#music-player-container", {
          opacity: 0,
          y: 30,
          duration: 0.5,
          ease: "power3.in",
        });
      },
    });

    document
      .getElementById("playPauseBtn")
      ?.addEventListener("click", togglePlayPause);
    document
      .getElementById("prevBtn")
      ?.addEventListener("click", previousTrack);
    document.getElementById("nextBtn")?.addEventListener("click", nextTrack);
    document
      .getElementById("progressBar")
      ?.addEventListener("input", seekAudio);

    const audio = document.getElementById("music-audio");
    if (audio instanceof HTMLAudioElement) {
      audio.addEventListener("loadedmetadata", () => {
        duration = audio.duration;
        updateTimeDisplay();
      });
    }
  });

  function togglePlayPause() {
    const audio = document.getElementById("music-audio");
    const playIcon = document.getElementById("play-icon");
    const pauseIcon = document.getElementById("pause-icon");
    const btn = document.getElementById("playPauseBtn");

    if (!(audio instanceof HTMLAudioElement)) return;

    if (!isPlaying) {
      audio.play().catch((e) => console.log("Error:", e));
      playIcon?.classList.add("hidden");
      pauseIcon?.classList.remove("hidden");
      gsap.to(btn, { scale: 1.2, duration: 0.15, yoyo: true, repeat: 1 });
      isPlaying = true;
      startProgress();
    } else {
      audio.pause();
      playIcon?.classList.remove("hidden");
      pauseIcon?.classList.add("hidden");
      isPlaying = false;
    }
  }

  function previousTrack() {
    const audio = document.getElementById("music-audio");
    if (audio instanceof HTMLAudioElement) audio.currentTime = 0;
    gsap.to("#prevBtn", { scale: 1.2, duration: 0.1, yoyo: true, repeat: 1 });
  }

  function nextTrack() {
    gsap.to("#nextBtn", { scale: 1.2, duration: 0.1, yoyo: true, repeat: 1 });
  }

  function seekAudio() {
    const bar = document.getElementById("progressBar");
    const audio = document.getElementById("music-audio");
    if (bar instanceof HTMLInputElement && audio instanceof HTMLAudioElement) {
      audio.currentTime = (Number(bar.value) / 100) * audio.duration;
      currentTime = audio.currentTime;
      updateTimeDisplay();
    }
  }

  function startProgress() {
    const audio = document.getElementById("music-audio");
    if (!(audio instanceof HTMLAudioElement)) return;

    const interval = setInterval(() => {
      if (!isPlaying) {
        clearInterval(interval);
        return;
      }
      currentTime = audio.currentTime;
      duration = audio.duration || duration;
      if (currentTime >= duration) {
        isPlaying = false;
        document.getElementById("play-icon")?.classList.remove("hidden");
        document.getElementById("pause-icon")?.classList.add("hidden");
        clearInterval(interval);
      }
      updateProgress();
    }, 100);
  }

  function updateProgress() {
    const bar = document.getElementById("progressBar");
    if (bar instanceof HTMLInputElement) {
      bar.value =
        duration > 0 ? ((currentTime / duration) * 100).toString() : "0";
    }
    updateTimeDisplay();
  }

  function updateTimeDisplay() {
    const audio = document.getElementById("music-audio");
    const currentEl = document.getElementById("currentTime");
    const totalEl = document.getElementById("totalDuration");

    if (!(audio instanceof HTMLAudioElement)) return;

    if (currentEl) {
      const m = Math.floor(audio.currentTime / 60);
      const s = Math.floor(audio.currentTime % 60)
        .toString()
        .padStart(2, "0");
      currentEl.textContent = `${m}:${s}`;
    }
    if (totalEl && audio.duration) {
      const m = Math.floor(audio.duration / 60);
      const s = Math.floor(audio.duration % 60)
        .toString()
        .padStart(2, "0");
      totalEl.textContent = `${m}:${s}`;
    }
  }
</script>

<style>
  #player-card {
    backdrop-filter: blur(20px);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.2),
      rgba(247, 231, 206, 0.1)
    );
  }

  .slider-elegant {
    background: linear-gradient(
      to right,
      #d4af37 0%,
      #d4af37 var(--progress, 0%),
      rgba(212, 175, 55, 0.2) var(--progress, 0%),
      rgba(212, 175, 55, 0.2) 100%
    );
    outline: none;
  }

  .slider-elegant::-webkit-slider-thumb {
    appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #d4af37;
    cursor: pointer;
    box-shadow: 0 0 6px rgba(212, 175, 55, 0.6);
    border: 2px solid white;
  }

  .slider-elegant::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #d4af37;
    cursor: pointer;
    border: 2px solid white;
  }
</style>
