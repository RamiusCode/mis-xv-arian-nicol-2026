---

<section class="py-10 px-6">
    <!-- Título -->
    <div class="text-center mb-8">
        <h2 class="font-great-vibes text-4xl md:text-5xl text-[#c9932a] mb-3">
            Galería de fotos
        </h2>
        <div class="flex items-center justify-center gap-3">
            <div
                class="w-12 h-[2px] bg-gradient-to-r from-transparent to-[#c9932a]"
            >
            </div>
            <div class="w-2 h-2 rounded-full bg-[#c9932a]"></div>
            <div
                class="w-12 h-[2px] bg-gradient-to-l from-transparent to-[#c9932a]"
            >
            </div>
        </div>
    </div>

    <!-- Grid de fotos -->
    <div class="grid grid-cols-2 gap-3 max-w-sm mx-auto">
        <!-- Foto 1 — ocupa 2 columnas -->
        <div
            class="foto-card col-span-2 cursor-pointer"
            data-foto="/imagenes/foto1.png"
        >
            <div
                class="relative group overflow-hidden rounded-2xl shadow-md aspect-video border border-[#c9932a]/20"
            >
                <img
                    src="/imagenes/foto1.png"
                    alt="Foto 1"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
                <div
                    class="absolute inset-0 bg-[#c9932a]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center"
                >
                    <span class="text-white text-2xl">🔍</span>
                </div>
            </div>
        </div>

        <!-- Foto 2 -->
        <div class="foto-card cursor-pointer" data-foto="/imagenes/foto2.png">
            <div
                class="relative group overflow-hidden rounded-2xl shadow-md aspect-square border border-[#c9932a]/20"
            >
                <img
                    src="/imagenes/foto2.png"
                    alt="Foto 2"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
                <div
                    class="absolute inset-0 bg-[#c9932a]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center"
                >
                    <span class="text-white text-2xl">🔍</span>
                </div>
            </div>
        </div>

        <!-- Foto 3 -->
        <div class="foto-card cursor-pointer" data-foto="/imagenes/foto3.png">
            <div
                class="relative group overflow-hidden rounded-2xl shadow-md aspect-square border border-[#c9932a]/20"
            >
                <img
                    src="/imagenes/foto3.png"
                    alt="Foto 3"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
                />
                <div
                    class="absolute inset-0 bg-[#c9932a]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center"
                >
                    <span class="text-white text-2xl">🔍</span>
                </div>
            </div>
        </div>

        <!-- Foto 4 -->
        <div class="foto-card cursor-pointer" data-foto="/imagenes/foto4.png">
            <div
                class="relative group overflow-hidden rounded-2xl shadow-md aspect-square border border-[#c9932a]/20"
            >
                <img
                    src="/imagenes/foto4.png"
                    alt="Foto 4"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
                />
                <div
                    class="absolute inset-0 bg-[#c9932a]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center"
                >
                    <span class="text-white text-2xl">🔍</span>
                </div>
            </div>
        </div>

        <!-- Foto 5 -->
        <div class="foto-card cursor-pointer" data-foto="/imagenes/foto5.png">
            <div
                class="relative group overflow-hidden rounded-2xl shadow-md aspect-square border border-[#c9932a]/20"
            >
                <img
                    src="/imagenes/foto5.png"
                    alt="Foto 5"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
                />
                <div
                    class="absolute inset-0 bg-[#c9932a]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center"
                >
                    <span class="text-white text-2xl">🔍</span>
                </div>
            </div>
        </div>

        <!-- Foto 6 — ocupa 2 columnas -->
        <div
            class="foto-card col-span-2 cursor-pointer"
            data-foto="/imagenes/foto6.png"
        >
            <div
                class="relative group overflow-hidden rounded-2xl shadow-md aspect-video border border-[#c9932a]/20"
            >
                <img
                    src="/imagenes/foto6.png"
                    alt="Foto 6"
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
                />
                <div
                    class="absolute inset-0 bg-[#c9932a]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center"
                >
                    <span class="text-white text-2xl">🔍</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL -->
<div
    id="modal-foto"
    class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 hidden items-center justify-center p-4"
>
    <button
        id="cerrar-modal"
        class="absolute top-4 right-4 w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white text-2xl transition-all z-10"
        >×</button
    >
    <div class="relative max-w-lg w-full" id="modal-contenido">
        <div
            class="bg-white rounded-2xl p-3 shadow-2xl border border-[#c9932a]/30"
        >
            <img
                id="modal-imagen"
                src=""
                alt="Foto ampliada"
                class="w-full h-auto max-h-[80vh] object-contain rounded-xl"
            />
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("modal-foto");
        const modalImagen = document.getElementById(
            "modal-imagen",
        ) as HTMLImageElement | null;
        const cerrarModal = document.getElementById("cerrar-modal");

        document.querySelectorAll(".foto-card").forEach((card) => {
            card.addEventListener("click", () => {
                const src = card.getAttribute("data-foto");
                if (modalImagen && modal && src) {
                    modalImagen.src = src;
                    modal.classList.remove("hidden");
                    modal.classList.add("flex");
                }
            });
        });

        const cerrar = () => {
            modal?.classList.add("hidden");
            modal?.classList.remove("flex");
        };

        cerrarModal?.addEventListener("click", cerrar);
        modal?.addEventListener("click", (e) => {
            if (e.target === modal) cerrar();
        });
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") cerrar();
        });
    });
</script>

<style>
    .foto-card:hover {
        transform: translateY(-4px);
        transition: transform 0.3s ease;
    }
</style>
