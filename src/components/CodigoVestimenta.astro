---

---

<section class="py-10 px-8 flex flex-col items-center text-center">
  <!-- Título estilo "Dress Code" -->
  <h2
    class="font-great-vibes text-4xl md:text-5xl text-[#c9932a] mb-6 drop-shadow-sm"
  >
    Dress Code
  </h2>

  <!-- Línea decorativa -->
  <div class="flex items-center gap-3 mb-8 w-full max-w-xs">
    <div class="flex-1 h-px bg-[#c9932a]/40"></div>
    <div class="w-2 h-2 rounded-full bg-[#c9932a]"></div>
    <div class="flex-1 h-px bg-[#c9932a]/40"></div>
  </div>

  <!-- Dos columnas -->
  <div class="grid grid-cols-2 gap-8 w-full max-w-xs">
    <!-- HOMBRES -->
    <div class="flex flex-col items-center gap-2">
      <!-- Icono traje -->
      <img
        src="/imagenes/hombre.png"
        alt="Traje formal hombre"
        class="w-16 h-16 object-contain icono-dorado"
      />
      <p class="font-charm text-base text-[#c9932a] font-bold tracking-wide">
        HOMBRES
      </p>
      <p class="font-charm text-sm text-[#7a5c2e] leading-snug">
        Traje Formal<br />(Camisa Blanca)
      </p>
    </div>

    <!-- MUJERES -->
    <div class="flex flex-col items-center gap-2">
      <!-- Icono vestido -->
      <img
        src="/imagenes/mujer.png"
        alt="Vestido formal mujer"
        class="w-16 h-16 object-contain icono-dorado"
      />
      <p class="font-charm text-base text-[#c9932a] font-bold tracking-wide">
        MUJERES
      </p>
      <p class="font-charm text-sm text-[#7a5c2e] leading-snug">
        Traje Formal<br />(Blanco)
      </p>
    </div>
  </div>

  <!-- Línea decorativa inferior -->
  <div class="flex items-center gap-3 mt-8 w-full max-w-xs">
    <div class="flex-1 h-px bg-[#c9932a]/40"></div>
    <div class="w-2 h-2 rounded-full bg-[#c9932a]"></div>
    <div class="flex-1 h-px bg-[#c9932a]/40"></div>
  </div>
</section>

<style>
  .icono-dorado {
    filter: brightness(0) saturate(100%) invert(55%) sepia(50%) saturate(600%)
      hue-rotate(5deg) brightness(95%) contrast(90%);
    transition:
      filter 0.3s ease,
      transform 0.3s ease;
  }
</style>
