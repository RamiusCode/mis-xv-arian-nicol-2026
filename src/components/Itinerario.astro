---

---

<section class="py-10 px-8">
  <!-- Título -->
  <div class="text-center mb-8">
    <h2
      class="font-charm text-2xl md:text-3xl text-[#c9932a] font-bold tracking-wide mb-3"
    >
      ITINERARIO
    </h2>
    <div class="flex items-center justify-center gap-3">
      <div class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#c9932a]">
      </div>
      <div class="w-2 h-2 rounded-full bg-[#c9932a]"></div>
      <div class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#c9932a]">
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="relative max-w-xs mx-auto">
    <!-- Línea vertical central -->
    <div
      class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] bg-[#c9932a]/40"
    >
    </div>

    <!-- EVENTO 1: Recepción — texto izq, icono der -->
    <div class="relative flex items-center py-5">
      <!-- Texto izquierda -->
      <div class="w-1/2 text-right pr-6">
        <p class="font-charm text-base text-[#c9932a] font-bold leading-tight">
          Recepción
        </p>
        <p class="font-charm text-sm text-[#7a5c2e]">19:00 hrs</p>
      </div>
      <!-- Corazón centrado en línea -->
      <div
        class="absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-[#c9932a] flex items-center justify-center z-10 shadow-md"
      >
        <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>
      <!-- Icono derecha -->
      <div class="w-1/2 flex justify-start pl-6">
        <img
          src="/imagenes/direccion.png"
          alt="Recepción"
          class="w-12 h-12 object-contain icono-dorado"
        />
      </div>
    </div>

    <!-- EVENTO 2: Vals — icono izq, texto der -->
    <div class="relative flex items-center py-5">
      <!-- Icono izquierda -->
      <div class="w-1/2 flex justify-end pr-6">
        <img
          src="/imagenes/vals.png"
          alt="Vals"
          class="w-12 h-12 object-contain icono-dorado"
        />
      </div>
      <!-- Corazón centrado en línea -->
      <div
        class="absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-[#c9932a] flex items-center justify-center z-10 shadow-md"
      >
        <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>
      <!-- Texto derecha -->
      <div class="w-1/2 text-left pl-6">
        <p class="font-charm text-base text-[#c9932a] font-bold leading-tight">
          Vals
        </p>
        <p class="font-charm text-sm text-[#7a5c2e]">21:00 hrs</p>
      </div>
    </div>

    <!-- EVENTO 3: Brindis — texto izq, icono der -->
    <div class="relative flex items-center py-5">
      <div class="w-1/2 text-right pr-6">
        <p class="font-charm text-base text-[#c9932a] font-bold leading-tight">
          Brindis
        </p>
        <p class="font-charm text-sm text-[#7a5c2e]">22:00 hrs</p>
      </div>
      <div
        class="absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-[#c9932a] flex items-center justify-center z-10 shadow-md"
      >
        <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>
      <div class="w-1/2 flex justify-start pl-6">
        <img
          src="/imagenes/brindis.png"
          alt="Brindis"
          class="w-12 h-12 object-contain icono-dorado"
        />
      </div>
    </div>

    <!-- EVENTO 4: Cena — icono izq, texto der -->
    <div class="relative flex items-center py-5">
      <div class="w-1/2 flex justify-end pr-6">
        <img
          src="/imagenes/cena.png"
          alt="Cena"
          class="w-12 h-12 object-contain icono-dorado"
        />
      </div>
      <div
        class="absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-[#c9932a] flex items-center justify-center z-10 shadow-md"
      >
        <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>
      <div class="w-1/2 text-left pl-6">
        <p class="font-charm text-base text-[#c9932a] font-bold leading-tight">
          Cena
        </p>
        <p class="font-charm text-sm text-[#7a5c2e]">22:30 hrs</p>
      </div>
    </div>

    <!-- EVENTO 5: Torta — texto izq, icono der -->
    <div class="relative flex items-center py-5">
      <div class="w-1/2 text-right pr-6">
        <p class="font-charm text-base text-[#c9932a] font-bold leading-tight">
          Torta
        </p>
        <p class="font-charm text-sm text-[#7a5c2e]">23:00 hrs</p>
      </div>
      <div
        class="absolute left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-[#c9932a] flex items-center justify-center z-10 shadow-md"
      >
        <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>
      <div class="w-1/2 flex justify-start pl-6">
        <img
          src="/imagenes/torta.png"
          alt="Torta"
          class="w-12 h-12 object-contain icono-dorado"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .icono-dorado {
    filter: brightness(0) saturate(100%) invert(55%) sepia(50%) saturate(600%)
      hue-rotate(5deg) brightness(95%) contrast(90%);
    transition:
      filter 0.3s ease,
      transform 0.3s ease;
  }
</style>
