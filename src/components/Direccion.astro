---

---

<section class="py-8 px-8 flex flex-col items-center text-center">
  <!-- Título -->
  <h2
    class="font-charm text-2xl md:text-3xl text-[#c9932a] font-bold tracking-wide mb-4"
  >
    RECEPCIÓN SOCIAL
  </h2>

  <!-- Icono -->
  <img
    src="/imagenes/direccion.png"
    alt="Icono de dirección"
    class="w-20 h-20 object-contain mb-4 icono-dorado"
  />

  <!-- Nombre del lugar -->
  <h3 class="font-charm text-xl text-[#c9932a] font-bold mb-2">Dirección</h3>

  <!-- Dirección -->
  <p class="font-charm text-base text-[#7a5c2e] leading-relaxed mb-2">
    Mario Olaguivel, pasando Hernando Siles, casi al final
  </p>

  <!-- Hora -->
  <p class="font-charm text-2xl text-[#c9932a] font-bold mb-6">Hora: 19:00</p>

  <!-- Botón -->
  <a
    href="https://maps.app.goo.gl/wUxpMCv4bPBrRSio6"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 px-8 py-3 bg-[#c9932a] rounded-xl shadow-md hover:bg-[#a27735] transition-all duration-300"
  >
    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
      ></path>
    </svg>
    <span class="font-charm text-lg text-white font-semibold"
      >Ver Ubicación</span
    >
  </a>
</section>

<style>
  .icono-dorado {
    filter: brightness(0) saturate(100%) invert(56%) sepia(12%) saturate(1486%)
      hue-rotate(359deg) brightness(92%) contrast(87%);
  }
</style>
